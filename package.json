{
  "name": "merit-aktiva-mcp",
  "version": "0.2.0",
  "description": "MCP server for the Merit Aktiva accounting API",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roosa-dev/merit-aktiva-mcp.git"
  },
  "keywords": [
    "mcp",
    "merit-aktiva",
    "accounting",
    "modelcontextprotocol"
  ],
  "bin": {
    "merit-aktiva-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/*.test.*"
  ],
  "engines": {
    "node": ">=21"
  },
  "scripts": {
    "prepublishOnly": "npm test",
    "build": "tsc",
    "test": "npm run build && node --test dist/*.test.js",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.2",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "agents": "^0.17.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "wrangler": "^4.112.0"
  }
}
